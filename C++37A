#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n; cin >> n;
    unordered_map<int, int> towers;
    int t=0, l=0, c;
    for (int i=0; i<n; i++){
      cin >> c;
      t+=(towers[c]==0);
      towers[c]++;
      l=max(l, towers[c]);
    }
    cout << l << " " << t;
}
